# ZeroClaw Smart Home v2 — Environment Configuration
# Copy this file to .env and fill in your values

# ── Anthropic Claude AI ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── API Server ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Tuya Cloud (optional for real devices) ──────────
TUYA_CLIENT_ID=your_tuya_client_id
TUYA_CLIENT_SECRET=your_tuya_client_secret
TUYA_REGION=eu

# ── Zigbee (optional) ───────────────────────────────
ZIGBEE_SERIAL_PORT=/dev/ttyUSB0
ZIGBEE2MQTT_HOST=localhost
ZIGBEE2MQTT_PORT=1883

# ── X10 (optional) ──────────────────────────────────
X10_SERIAL_PORT=/dev/ttyS0
